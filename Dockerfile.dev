FROM golang:1.22-alpine

WORKDIR /app

# Install development tools: air and tailwindcss
RUN apk add --no-cache git curl && \
    go install github.com/air-verse/air@latest

# Copy dependency files
COPY go.mod go.sum ./
RUN go mod download

# Expose port
EXPOSE 8080

# Run Air for live-reload development
CMD ["air", "-c", ".air.toml"]
