{
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "experimental": {
          "classRegex": [
            "Class\\(\"([^\"]*)\"\\)",
            "Class\\([^,]+,\\s*\"([^\"]*)\"\\)"
          ]
        },
        "includeLanguages": {
          "go": "html"
        }
      }
    }
  }
}
